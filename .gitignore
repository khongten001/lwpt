# Build artefacts (per the native-nostalgia-stack build-system contract,
# everything output by the build lands under build/ and is not committed).
build/

# LWPT toolkit state — the install workspace and the ephemeral install
# lock. The committed state under .lwpt/modules/ and .lwpt/archives/ is
# NOT gitignored (per ADR-0002 zero-install).
.lwpt/tmp/
.lwpt/install.lock
.lwpt/sessions/

# FPC artefacts. These should never appear with -FE build, but defensive
# in case a contributor runs fpc by hand without the output-dir flag.
*.o
*.ppu
*.rsj
*.compiled

# OS noise.
.DS_Store
Thumbs.db

# Per-session agent handoff state — local working notes only, never
# committed (.agents/ with an "s" is the committed skills dir).
.agent/
